# ───────────────────────────────────────────────────────────────────────────
# ASG Backend environment
# Copy to .env and fill in. Never commit the real .env.
# ───────────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development
# Comma-separated list of allowed CORS origins. Use * only for local testing.
CORS_ORIGINS=https://www.alexstoykovgroup.com,https://alexstoykovgroup.com
# Shared secret required for write/sync endpoints (POST /api/sync/*, secured actions).
WEBHOOK_SECRET=change-me-long-random-string

# ── Supabase ────────────────────────────────────────────────────────────────
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=
# Service role key (server only — full access, bypasses RLS). NEVER expose to browsers.
SUPABASE_SERVICE_ROLE_KEY=
# Anon (publishable) key — used for signup/login proxy + JWT verification. Safe for browsers.
SUPABASE_ANON_KEY=
# Direct Postgres connection string (Supabase: Project Settings > Database > Connection string > URI).
# Use the pooled connection (port 6543) for the API and the direct (5432) for migrations.
DATABASE_URL=postgres://postgres:password@db.abcdefgh.supabase.co:5432/postgres
# Storage bucket names (created by migration 0008; override if you renamed them).
STORAGE_BUCKET_LISTINGS=listing-photos
STORAGE_BUCKET_HEADSHOTS=headshots
STORAGE_BUCKET_BRAND=brand-assets

# ── Follow Up Boss (CRM) ─────────────────────────────────────────────────────
FUB_API_KEY=
FUB_API_BASE_URL=https://api.followupboss.com/v1
# Comma-separated FUB user ids treated as admin task assignees.
FUB_ADMIN_USER_IDS=
FUB_DEAL_TRACKER_SMART_LIST_ID=172
FUB_DEAL_TRACKER_SMART_LIST_NAME=Current Deals
# Defaults applied when creating leads.
BUYER_INTAKE_SOURCE=ASG Website - Buyer Onboarding
BUYER_INTAKE_SYSTEM=ASG Website
BUYER_INTAKE_FALLBACK_EMAIL=alex.stoykov@compass.com
SELLER_INTAKE_SOURCE=ASG Website - Seller Onboarding
SELLER_INTAKE_SYSTEM=ASG Website
SELLER_INTAKE_FALLBACK_EMAIL=alex.stoykov@compass.com

# ── IDX Broker / Elm Street (MLS) ────────────────────────────────────────────
IDX_ACCESS_KEY=
IDX_API_VERSION=1.7
IDX_API_BASE_URL=https://api.idxbroker.com

# ── Google Drive (listing photos + assets) ──────────────────────────────────
# Service account JSON key (stringified) OR path to the key file. The service
# account must have at least viewer access to the ASG Drive folders below.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=
DRIVE_LISTING_PHOTOS_ROOT=1FY64_Fe-jVDUIb6hWzwPFdo6fotm7Ztn
DRIVE_AGENT_FOLDERS_ROOT=1zIfDqSpA94cRFajB3TsA3ryJibKSinIK
DRIVE_BRAND_ASSETS_ROOT=1Z3-1_Y_oGvvvLR6ZXVB1PkGr03i9tYEx

# ── Asana (marketing requests) ───────────────────────────────────────────────
ASANA_TOKEN=
ASANA_WORKSPACE_GID=
ASANA_MARKETING_PROJECT_GID=

# ── Acuity (photo shoot bookings) ─────────────────────────────────────────────
ACUITY_USER_ID=
ACUITY_API_KEY=
ACUITY_CALENDAR_IDS=

# ── Pipeline CSVs (published Google Sheets) ──────────────────────────────────
PIPELINE_BUYERS_CSV=https://docs.google.com/spreadsheets/d/e/2PACX-1vRP9DdHc1LRiDAruzEhCvnhOgYfCwgO4Q--5rkENDD4zxwn6UKD40Ux817lNI5kFTIpdeBJj1oieNqs/pub?gid=1143085145&single=true&output=csv
PIPELINE_SELLERS_CSV=https://docs.google.com/spreadsheets/d/e/2PACX-1vRP9DdHc1LRiDAruzEhCvnhOgYfCwgO4Q--5rkENDD4zxwn6UKD40Ux817lNI5kFTIpdeBJj1oieNqs/pub?gid=1110212825&single=true&output=csv

# ── Anthropic (listing marketing agent) ──────────────────────────────────────
# Drafts an on-brand, Fair-Housing-compliant marketing package for human review.
# Drafts only — never auto-publishes to the site, FUB, or MLS. Leave the key
# blank to disable the agent entirely (have.anthropic() gates everything).
ANTHROPIC_API_KEY=
# Optional override (proxy / gateway). Leave blank for the default endpoint.
ANTHROPIC_BASE_URL=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_HAIKU_MODEL=claude-haiku-4-5
# Master switch for the worker/cron (also requires ANTHROPIC_API_KEY).
LISTING_AGENT_ENABLED=false
# Hard token ceiling per run — abort + fail the job if exceeded (~$1/listing).
LISTING_AGENT_MAX_TOKENS_PER_RUN=120000

# ── Scheduler ────────────────────────────────────────────────────────────────
# Set ENABLE_SCHEDULER=true to run cron syncs inside the API process.
ENABLE_SCHEDULER=false
CRON_IDX=*/15 * * * *
CRON_FUB=*/30 * * * *
CRON_PIPELINE=*/30 * * * *
CRON_PHOTOS=0 * * * *
CRON_DIRECTORY=0 6 * * *
CRON_MARKETING=*/30 * * * *
# Listing marketing agent worker (claims queued jobs).
CRON_LISTING_AGENT=*/2 * * * *
